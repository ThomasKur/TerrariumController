@page "/"
@using TerrariumController.Services
@using TerrariumController.Models
@rendermode InteractiveServer
@inject ISensorService SensorService
@inject IRelayService RelayService
@inject ISettingsService SettingsService
@inject ILogger<Home> Logger
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Terrarium Controller</PageTitle>

<div class="dashboard">
    <header class="hero">
        <div>
            <p class="eyebrow">Terrarium Controller</p>
            <h1>Live Environment Overview</h1>
            <p class="lede">Monitor temperatures, humidity, and daylight schedule at a glance.</p>
        </div>
    </header>

    <section class="dashboard-toolbar" aria-label="Dashboard actions">
        <div class="meta-item compact-meta">
            <span class="meta-label">Last Updated</span>
            <span class="meta-value">@CurrentTime.ToString("HH:mm:ss")</span>
        </div>
        <div class="action-strip">
            <a href="/settings" class="settings-link" aria-label="Open settings page">
                <span class="settings-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M19.4 13a7.8 7.8 0 0 0 .1-1 7.8 7.8 0 0 0-.1-1l2-1.6a.5.5 0 0 0 .1-.6l-1.9-3.2a.5.5 0 0 0-.6-.2l-2.4 1a7.6 7.6 0 0 0-1.7-1l-.4-2.5a.5.5 0 0 0-.5-.4h-3.8a.5.5 0 0 0-.5.4l-.4 2.5a7.6 7.6 0 0 0-1.7 1l-2.4-1a.5.5 0 0 0-.6.2L2.5 8.8a.5.5 0 0 0 .1.6l2 1.6a7.8 7.8 0 0 0-.1 1 7.8 7.8 0 0 0 .1 1l-2 1.6a.5.5 0 0 0-.1.6l1.9 3.2a.5.5 0 0 0 .6.2l2.4-1a7.6 7.6 0 0 0 1.7 1l.4 2.5a.5.5 0 0 0 .5.4h3.8a.5.5 0 0 0 .5-.4l.4-2.5a7.6 7.6 0 0 0 1.7-1l2.4 1a.5.5 0 0 0 .6-.2l1.9-3.2a.5.5 0 0 0-.1-.6zm-7.4 2.5A3.5 3.5 0 1 1 12 8.5a3.5 3.5 0 0 1 0 7z" />
                    </svg>
                </span>
                <span>Settings</span>
            </a>
            <a href="/logs" class="settings-link logs-link" aria-label="Open logs page">
                <span class="settings-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M9 3h6a2 2 0 0 1 2 2h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h2a2 2 0 0 1 2-2zm0 2v2h6V5zm-2 5h10v2H7zm0 4h10v2H7z" />
                    </svg>
                </span>
                <span>Logs</span>
            </a>
            <button @onclick="ShowExitConfirm" class="settings-link exit-link" aria-label="Exit kiosk mode">
                <span class="settings-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M3 4a2 2 0 0 1 2-2h11v20H5a2 2 0 0 1-2-2zm6 8 0 2h6v3l5-4-5-4v3z" />
                    </svg>
                </span>
                <span>Exit</span>
            </button>
        </div>
    </section>

    <section class="dashboard-shell">
        <div class="control-panel">
            <section class="sensor-grid">
                @if (IsLoadingSensors)
                {
                    <div class="card status-card">
                        <span>Loading sensors...</span>
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrWhiteSpace(SensorLoadError))
                    {
                        <div class="card status-card warning" role="status" aria-live="polite">
                            <span>@SensorLoadError</span>
                        </div>
                    }

                    @foreach (var reading in CurrentReadings.OrderBy(r => r.SensorId))
                    {
                        <div class="card sensor-card @(IsRelayOn(reading.SensorId) ? "heating" : "")">
                            <div class="card-header">
                                <span class="pill">Sensor @reading.SensorId</span>
                                <span class="label">@reading.Label</span>
                                @if (IsRelayOn(reading.SensorId))
                                {
                                    <span class="heating-badge" role="status" aria-label="Relay @reading.SensorId heating">Heating</span>
                                }
                            </div>
                            <div class="metrics">
                                <div class="metric">
                                    <div class="metric-value">
                                        <span>@(reading.Temperature?.ToString("F1") ?? "--")°C</span>
                                        <small class="threshold-inline">/ @GetThresholdDisplay(reading.SensorId)</small>
                                    </div>
                                    <div class="metric-label">Temperature</div>
                                </div>
                                <div class="metric">
                                    <div class="metric-value">@(reading.Humidity?.ToString("F0") ?? "--")%</div>
                                    <div class="metric-label">Humidity</div>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="card sensor-card scheduler-card">
                        <div class="card-header">
                            <span class="pill">Relay 4</span>
                            <span class="label">Daylight Schedule</span>
                        </div>
                        <div class="schedule-status" role="status" aria-live="polite">
                            @(IsRelayOn(4) ? "Day mode" : "Night mode")
                        </div>
                    </div>
                }
            </section>
        </div>

        <aside class="card camera-panel">
            <div class="card-header">
                <span class="pill">Camera</span>
                <span class="label">Live Feed</span>
            </div>
            <div class="camera-frame">
                <img id="camera-feed" alt="Camera" />
            </div>
        </aside>
    </section>

    @if (ShowConfirmDialog)
    {
        <div class="confirm-dialog">
            <div class="confirm-box">
                <h2>Exit Kiosk Mode?</h2>
                <p>This will close the browser. The service will continue running.</p>
                <div class="confirm-buttons">
                    <button @onclick="CancelExit" class="confirm-btn confirm-btn-cancel">Cancel</button>
                    <button @onclick="ExitKiosk" class="confirm-btn confirm-btn-exit">Exit</button>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .dashboard {
        display: flex;
        flex-direction: column;
        gap: 12px;
        color: #e7edf7;
    }

    .hero {
        display: none;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
    }

    .eyebrow {
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-size: 12px;
        color: #7bd7ff;
        margin: 0 0 6px 0;
    }

    .hero h1 {
        margin: 0 0 4px 0;
        font-size: 24px;
        color: #f5f9ff;
    }

    .lede {
        margin: 0;
        color: #a6b3c9;
    }

    .dashboard-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .action-strip {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
    }

    .meta-item {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 10px;
        padding: 10px 12px;
        min-width: 120px;
    }

    .compact-meta {
        min-width: 112px;
    }

    .meta-label {
        display: block;
        font-size: 12px;
        color: #8ea0bd;
    }

    .meta-value {
        font-weight: 600;
        color: #f5f9ff;
    }

    .settings-link {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(123, 215, 255, 0.12);
        border: 1px solid rgba(123, 215, 255, 0.3);
        border-radius: 10px;
        padding: 10px 14px;
        color: #7bd7ff;
        text-decoration: none;
        font-weight: 600;
        font-size: 13px;
        transition: all 0.2s ease;
    }

    .settings-link:hover {
        background: rgba(123, 215, 255, 0.2);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(123, 215, 255, 0.25);
    }

    .logs-link {
        background: rgba(167, 139, 250, 0.12);
        border-color: rgba(167, 139, 250, 0.3);
        color: #c4b5fd;
    }

    .logs-link:hover {
        background: rgba(167, 139, 250, 0.22);
        box-shadow: 0 4px 12px rgba(167, 139, 250, 0.25);
    }

    .exit-link {
        background: rgba(239, 68, 68, 0.12);
        border-color: rgba(239, 68, 68, 0.3);
        color: #fca5a5;
        border: 1px solid rgba(239, 68, 68, 0.3);
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .exit-link:hover {
        background: rgba(239, 68, 68, 0.22);
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25);
    }

    .confirm-dialog {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    .confirm-box {
        background: linear-gradient(160deg, rgba(34, 45, 64, 0.95), rgba(20, 28, 43, 0.98));
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        padding: 20px;
        max-width: 400px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    }

    .confirm-box h2 {
        color: #f5f9ff;
        margin: 0 0 12px 0;
        font-size: 1.25rem;
    }

    .confirm-box p {
        color: #cfd9e8;
        margin: 0 0 20px 0;
        line-height: 1.5;
    }

    .confirm-buttons {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
    }

    .confirm-btn {
        padding: 10px 16px;
        border: none;
        border-radius: 10px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
    }

    .confirm-btn-cancel {
        background: rgba(255, 255, 255, 0.08);
        color: #a6b3c9;
        border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .confirm-btn-cancel:hover {
        background: rgba(255, 255, 255, 0.12);
        color: #e7edf7;
    }

    .confirm-btn-exit {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: #fff;
    }

    .confirm-btn-exit:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 20px rgba(239, 68, 68, 0.35);
    }

    .settings-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 16px;
        height: 16px;
        line-height: 1;
    }

    .settings-icon svg {
        width: 16px;
        height: 16px;
        fill: currentColor;
    }

    .dashboard-shell {
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
        gap: 12px;
        align-items: stretch;
    }

    .control-panel {
        min-width: 0;
    }

    .sensor-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .sensor-card.heating {
        border-color: rgba(255, 140, 60, 0.55);
        box-shadow: 0 0 0 1px rgba(255, 140, 60, 0.2), 0 12px 40px rgba(0, 0, 0, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.03);
    }

    .heating-badge {
        font-size: 12px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 999px;
        background: rgba(255, 140, 60, 0.15);
        color: #ffb060;
        border: 1px solid rgba(255, 140, 60, 0.4);
        white-space: nowrap;
    }

    .status-card {
        display: flex;
        align-items: center;
        min-height: 72px;
        grid-column: 1 / -1;
    }

    .status-card.warning {
        border-color: rgba(255, 204, 102, 0.55);
        background: linear-gradient(160deg, rgba(62, 45, 18, 0.7), rgba(34, 28, 14, 0.85));
        color: #ffd88a;
    }

    .card {
        background: linear-gradient(160deg, rgba(34, 45, 64, 0.8), rgba(20, 28, 43, 0.9));
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 14px;
        padding: 12px;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.03);
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 10px;
        padding-left: 0px;
        padding-right: 0px;
    }

    .pill {
        font-size: 12px;
        padding: 4px 10px;
        border-radius: 999px;
        background: rgba(123, 215, 255, 0.12);
        color: #7bd7ff;
        border: 1px solid rgba(123, 215, 255, 0.3);
    }

    .label {
        color: #cfd9e8;
        font-weight: 600;
    }

    .metrics {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
    }

    .metric-value {
        font-size: 22px;
        font-weight: 600;
        color: #f5f9ff;
        line-height: 1.05;
        display: inline-flex;
        align-items: baseline;
        gap: 6px;
        flex-wrap: wrap;
    }

    .threshold-inline {
        font-size: 12px;
        font-weight: 500;
        color: #8ea0bd;
    }

    .metric-label {
        font-size: 12px;
        color: #8ea0bd;
    }

    .schedule-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 0 12px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: #f5f9ff;
        font-weight: 600;
    }

    .camera-panel {
        display: flex;
        flex-direction: column;
        min-height: 100%;
    }

    .camera-frame {
        margin-top: 8px;
        background: #0b1018;
        border-radius: 12px;
        border: 1px solid rgba(123, 215, 255, 0.15);
        overflow: hidden;
        aspect-ratio: 4 / 3;
        flex: 1;
    }

    .camera-frame img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    @@media (max-width: 700px) {
        .dashboard-shell {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 900px) and (max-height: 520px) and (orientation: landscape) {
        .dashboard {
            gap: 8px;
        }

        .dashboard-toolbar {
            gap: 8px;
        }

        .meta-item {
            padding: 7px 10px;
            min-width: 96px;
        }

        .meta-label {
            font-size: 11px;
        }

        .settings-link {
            padding: 8px 10px;
            font-size: 12px;
            gap: 6px;
        }

        .settings-icon,
        .settings-icon svg {
            width: 14px;
            height: 14px;
        }

        .dashboard-shell {
            grid-template-columns: minmax(0, 1.2fr) minmax(230px, 0.8fr);
            gap: 8px;
            min-height: 0;
        }

        .sensor-grid {
            gap: 8px;
        }

        .card {
            padding: 9px;
            border-radius: 12px;
        }

        .card-header {
            margin-bottom: 7px;
        }

        .pill {
            font-size: 11px;
            padding: 3px 8px;
        }

        .label {
            font-size: 13px;
        }

        .metric-value {
            font-size: 18px;
        }

        .threshold-inline,
        .metric-label {
            font-size: 11px;
        }

        .heating-badge {
            font-size: 11px;
            padding: 2px 8px;
        }

        .camera-panel {
            min-height: 0;
        }

        .camera-frame {
            margin-top: 6px;
            aspect-ratio: auto;
            min-height: 0;
            height: 100%;
        }
    }

    @@media (max-width: 768px) {
        .hero {
            display: flex;
            flex-direction: column;
        }

        .dashboard-toolbar {
            flex-direction: column;
            align-items: stretch;
        }

        .action-strip {
            width: 100%;
            justify-content: stretch;
        }

        .action-strip > * {
            flex: 1 1 0;
            justify-content: center;
        }

        .sensor-grid {
            grid-template-columns: 1fr;
        }

        .camera-frame {
            aspect-ratio: 16 / 10;
        }
    }
</style>

@code {
    private List<SensorReadingModel> CurrentReadings = new();
    private Dictionary<int, bool> RelayStates = new();
    private DateTime CurrentTime = DateTime.Now;
    private bool IsLoadingSensors = true;
    private string? SensorLoadError;
    private Dictionary<int, double> Thresholds = new();
    private CancellationTokenSource? _refreshCts;
    private Task? _clockTask;
    private Task? _sensorRefreshTask;
    private bool _backgroundTasksStarted;
    private bool _isDisposed;

    [Parameter]
    public TimeSpan ClockRefreshInterval { get; set; } = TimeSpan.FromSeconds(1);

    [Parameter]
    public TimeSpan SensorRefreshInterval { get; set; } = TimeSpan.FromSeconds(10);

    protected override async Task OnInitializedAsync()
    {
        await RefreshReadings(isInitialLoad: true);

        StartBackgroundTasks();
    }

    private void StartBackgroundTasks()
    {
        if (_backgroundTasksStarted)
        {
            return;
        }

        _refreshCts = new CancellationTokenSource();
        _clockTask = RunClockAsync(_refreshCts.Token);
        _sensorRefreshTask = RunSensorRefreshAsync(_refreshCts.Token);
        _backgroundTasksStarted = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_isDisposed)
        {
            await JS.InvokeVoidAsync("startCameraSnapshot", "/camera/snapshot.jpg");
        }
        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task RefreshReadings(bool isInitialLoad = false)
    {
        try
        {
            var readings = await SensorService.GetLatestReadingsAsync();
            CurrentReadings = readings.Select(r => new SensorReadingModel
            {
                SensorId = r.SensorId,
                Label = r.Label ?? $"Sensor {r.SensorId}",
                Temperature = r.Temperature,
                Humidity = r.Humidity,
                IsValid = r.IsValid
            }).ToList();

            var settings = await SettingsService.GetSettingsAsync();
            Thresholds = new Dictionary<int, double>
            {
                { 1, settings.Threshold1Temperature },
                { 2, settings.Threshold2Temperature },
                { 3, settings.Threshold3Temperature }
            };

            RelayStates = await RelayService.GetAllRelayStatesAsync();
            SensorLoadError = null;
        }
        catch (Exception ex)
        {
            SensorLoadError = "Sensor data unavailable. Showing last known values.";
            Logger.LogWarning(ex, "Unable to refresh sensor readings for home page");
        }
        finally
        {
            if (isInitialLoad)
            {
                IsLoadingSensors = false;
            }
        }
    }

    private async Task RunClockAsync(CancellationToken cancellationToken)
    {
        var interval = ClockRefreshInterval > TimeSpan.Zero
            ? ClockRefreshInterval
            : TimeSpan.FromSeconds(1);

        try
        {
            using var timer = new PeriodicTimer(interval);
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                CurrentTime = DateTime.Now;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task RunSensorRefreshAsync(CancellationToken cancellationToken)
    {
        var interval = SensorRefreshInterval > TimeSpan.Zero
            ? SensorRefreshInterval
            : TimeSpan.FromSeconds(10);

        try
        {
            using var timer = new PeriodicTimer(interval);
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await RefreshReadings();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private bool IsRelayOn(int sensorId)
    {
        return RelayStates.TryGetValue(sensorId, out var state) && state;
    }

    private string GetThresholdDisplay(int sensorId)
    {
        return Thresholds.TryGetValue(sensorId, out var threshold)
            ? $"{threshold:F1}°C"
            : "--";
    }

    private bool ShowConfirmDialog = false;

    private void ShowExitConfirm()
    {
        ShowConfirmDialog = true;
    }

    private void CancelExit()
    {
        ShowConfirmDialog = false;
    }

    private async Task ExitKiosk()
    {
        ShowConfirmDialog = false;

        try
        {
            await JS.InvokeVoidAsync("closeKioskWindow");
        }
        catch (JSException ex)
        {
            Logger.LogWarning(ex, "Unable to trigger kiosk close from the home page");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_isDisposed)
        {
            return;
        }

        _isDisposed = true;

        var refreshCts = _refreshCts;
        if (refreshCts == null)
        {
            return;
        }

        _refreshCts = null;
        refreshCts.Cancel();

        var tasks = new[] { _clockTask, _sensorRefreshTask }
            .Where(task => task != null)
            .Cast<Task>();

        try
        {
            await Task.WhenAll(tasks);
        }
        catch (OperationCanceledException)
        {
        }

        refreshCts.Dispose();
        _clockTask = null;
        _sensorRefreshTask = null;
    }

    private class SensorReadingModel
    {
        public int SensorId { get; set; }
        public string Label { get; set; } = "";
        public double? Temperature { get; set; }
        public double? Humidity { get; set; }
        public bool IsValid { get; set; }
    }
}
